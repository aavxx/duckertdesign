{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Duckert Admin",
  "version": "1.0.0",
  "identifier": "design.duckert.admin",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": "default-src 'self' tauri: asset:; connect-src 'self' https://duckert.design; img-src 'self' data: tauri: asset: https:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"
    },
    "windows": [
      {
        "title": "Duckert Admin",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": true,
        "closable": true,
        "visible": false
      }
    ],
    "trayIcon": {
      "id": "main-tray",
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "tooltip": "Duckert Admin"
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    }
  },
  "plugins": {
    "notification": {},
    "autostart": {
      "args": [],
      "name": "DuckertAdmin"
    }
  }
}
